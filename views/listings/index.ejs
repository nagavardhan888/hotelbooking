<% layout("/layouts/boilerplate") %>
    <div class="row row-cols-lg-3 rows-cols-md-3 rows-cols-sm-1">
    <% for(let listing of listings){ %>
      <a href="/listings/<%=listing._id%>" class="listing-link" >
  <div class="card" style="width: 20rem;">
<img src="<%= listing.image.url || listing.image %>" class="card-img-top" alt="listing image" style="height:20rem">
<div class="card-img-overlay"></div>
  <div class="card-body">
    <p class="card-text">
        <h5><%= listing.title %></h5>
        <!-- <p><%= listing.description %></p> -->
        <p>Price: &#8377;<%= listing.price.toLocaleString("en-IN") %>/night</p>
        <!-- <p>Location: <%= listing.location %></p> -->
    </p>
  </div>
</div>
<% } %> 
</div>
</a>